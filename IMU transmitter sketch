#include <Wire.h>
#include <SPI.h>
#include <RF24.h>

// ---- NRF24 ----
RF24 radio(9, 10);                     // CE, CSN
const byte address[6] = "00001";

// ---- MPU6050 ----
#define MPU6050_ADDR  0x68
#define GYRO_XOUT_H   0x43

#define DEADZONE      10.0f            // °/s threshold
#define SEND_INTERVAL 80              // ms between transmissions

float    gyroScale    = 131.0f;
long     gyroZ_offset = 0;
unsigned long lastSend = 0;

void calibrateGyro() {
  long sumZ = 0;
  for (int i = 0; i < 200; i++) {
    Wire.beginTransmission(MPU6050_ADDR);
    Wire.write(GYRO_XOUT_H);
    Wire.endTransmission(false);
    Wire.requestFrom(MPU6050_ADDR, 6, true);
    Wire.read(); Wire.read();           // skip X
    Wire.read(); Wire.read();           // skip Y
    sumZ += (int16_t)((Wire.read() << 8) | Wire.read());
    delay(5);
  }
  gyroZ_offset = sumZ / 200;
}

char readCommand() {
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(GYRO_XOUT_H);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU6050_ADDR, 6, true);
  Wire.read(); Wire.read();             // skip X
  Wire.read(); Wire.read();             // skip Y
  int16_t rawZ = (Wire.read() << 8) | Wire.read();
  rawZ -= (int16_t)gyroZ_offset;
  float gz = rawZ / gyroScale;

  if      (gz >  DEADZONE) return 'R';
  else if (gz < -DEADZONE) return 'L';
  else                     return 'C';
}

void setup() {
  Wire.begin();

  // Wake MPU6050
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x6B); Wire.write(0);
  Wire.endTransmission();
  delay(100);

  calibrateGyro();

  radio.begin();
  radio.openWritingPipe(address);
  radio.setPALevel(RF24_PA_LOW);       // increase to RF24_PA_HIGH if range is poor
  radio.stopListening();
}

void loop() {
  unsigned long now = millis();
  if (now - lastSend < SEND_INTERVAL) return;
  lastSend = now;

  char cmd = readCommand();
  radio.write(&cmd, sizeof(cmd));
}
