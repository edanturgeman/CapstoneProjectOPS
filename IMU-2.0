#include <Wire.h>

// MPU6050 Registers
#define MPU6050_ADDR   0x68
#define GYRO_XOUT_H    0x43

// Calibration
long gyroZ_offset = 0;
float gyroScale = 131.0; 

// --- ANGLE TRACKING VARIABLES ---
float currentAngle = 0.0;
unsigned long lastTime = 0;

// --- TUNING PARAMETERS ---
// 1. Noise Floor: Ignore tiny velocity readings to prevent "drift" when the wheel is still
#define VELOCITY_DEADZONE 1.5 
// 2. Lane Boundary: How many degrees the wheel must be turned to change lanes
#define LANE_ANGLE_THRESHOLD 25.0 

// State tracking
char lastCommand = 'C'; 

void setup() {
  Serial.begin(9600);
  Wire.begin();

  // Wake up MPU6050
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x6B);
  Wire.write(0);
  Wire.endTransmission();

  delay(1000);
  calibrateGyroscope();
  
  Serial.println("System Ready. Send 'C' to sync initial state.");
  
  // Initialize the timer right before the loop starts
  lastTime = millis();
}

void loop() {
  int16_t rawGyroZ;

  // Read Gyroscope Z-axis
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(GYRO_XOUT_H + 4); 
  Wire.endTransmission(false);
  Wire.requestFrom(MPU6050_ADDR, 2, true);

  rawGyroZ = (Wire.read() << 8) | Wire.read();
  rawGyroZ -= gyroZ_offset;

  float gz = rawGyroZ / gyroScale;

  // --- 1. CALCULATE DELTA TIME (dt) ---
  unsigned long currentTime = millis();
  float dt = (currentTime - lastTime) / 1000.0; // Convert milliseconds to seconds
  lastTime = currentTime;

  // --- 2. INTEGRATE VELOCITY INTO ANGLE ---
  // Only add to the angle if the movement is larger than the noise floor
  if (abs(gz) > VELOCITY_DEADZONE) {
    currentAngle += (gz * dt);
  }

  // --- 3. DETERMINE LANE COMMAND ---
  char currentCommand = getLaneFromAngle(currentAngle);

  // --- 4. TRANSMIT ON STATE CHANGE ONLY ---
  if (currentCommand != lastCommand) {
    Serial.println(currentCommand);
    lastCommand = currentCommand; 
  }

  // A short delay keeps the integration accurate. 
  // Do not make this larger than 20-30ms, or dt will become too staggered.
  delay(20); 
}

char getLaneFromAngle(float angle) {
  if (angle > LANE_ANGLE_THRESHOLD) {
    return 'R';
  } else if (angle < -LANE_ANGLE_THRESHOLD) {
    return 'L';
  } else {
    return 'C';
  }
}

void calibrateGyroscope() {
  long sumZ = 0;
  Serial.println("Calibrating... Keep steering wheel perfectly still.");
  for (int i = 0; i < 200; i++) {
    Wire.beginTransmission(MPU6050_ADDR);
    Wire.write(GYRO_XOUT_H + 4);
    Wire.endTransmission(false);
    Wire.requestFrom(MPU6050_ADDR, 2, true);
    sumZ += (Wire.read() << 8) | Wire.read();
    delay(5);
  }
  gyroZ_offset = sumZ / 200;
  Serial.println("Calibration Done.");
}
